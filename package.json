{
  "name": "voda-agile-board",
  "version": "1.0.0",
  "description": "Agile reporting for scrum masters and leaders - sprint reports from Jira (MPSA & MAS)",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "build:css": "node scripts/build-css.js",
    "check:css": "node scripts/check-css.js",
    "dev": "nodemon server.js",
    "prestart": "npm run build:css",
    "start": "node server.js",
    "auth:supertokens:up": "docker compose -f docker-compose.supertokens.yml up -d",
    "auth:supertokens:down": "docker compose -f docker-compose.supertokens.yml down",
    "test:all": "node scripts/Jira-Reporting-App-Test-Orchestration-Runner.js",
    "test:all:stop": "node scripts/Jira-Reporting-App-Test-Orchestration-Stop.js",
    "test:pw": "playwright test --max-failures=1 --reporter=list",
    "test:smoke": "node scripts/Jira-Reporting-Tests-Journey-Runner-SSOT.js journey.ux-core -- --grep \"stories card is first content\"",
    "test:journey:current-sprint": "node scripts/Jira-Reporting-Tests-Journey-Runner-SSOT.js journey.current-sprint",
    "test:journey:leadership": "node scripts/Jira-Reporting-Tests-Journey-Runner-SSOT.js journey.leadership",
    "test:journey:outcome-intake": "node scripts/Jira-Reporting-Tests-Journey-Runner-SSOT.js journey.outcome-intake",
    "test:journey:ux-core": "node scripts/Jira-Reporting-Tests-Journey-Runner-SSOT.js journey.ux-core",
    "test:journey:shell-direct-value": "node scripts/Jira-Reporting-Tests-Journey-Runner-SSOT.js journey.shell-direct-value",
    "test:journey:data-integrity": "node scripts/Jira-Reporting-Tests-Journey-Runner-SSOT.js journey.data-integrity",
    "test:e2e:full": "node scripts/Jira-Reporting-Tests-Journey-Runner-SSOT.js journey.e2e",
    "test:api:core": "npm run test:journey:data-integrity",
    "test:data:integrity": "npm run test:journey:data-integrity",
    "test:current-sprint:core": "npm run test:journey:current-sprint",
    "test:ux:core": "npm run test:journey:ux-core",
    "test:report-current-shell": "npm run test:journey:shell-direct-value",
    "test:current-sprint-ux-ssot": "npm run test:journey:current-sprint",
    "test:current-sprint-redesign": "npm run test:journey:current-sprint",
    "test:e2e": "npm run test:e2e:full"
  },
  "keywords": [
    "voda-agile-board",
    "agile",
    "reporting",
    "sprint",
    "jira"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "jira.js": "^5.3.0",
    "redis": "^4.7.0",
    "supertokens-node": "^24.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
